# ===== Database (PostgreSQL) =====
# Buat database di Vercel Storage (Postgres/Neon) atau Neon/Supabase/Railway.
# Tempel connection string pooled di sini, lalu jalankan sql/schema.sql sekali
# untuk membuat semua tabel.
POSTGRES_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ===== Zakki Gateway =====
ZAKKI_TOKEN=22ab8cb71fe2bb
ZAKKI_API=https://qris.zakki.store

# ===== Auth =====
# WAJIB diisi string random panjang (minimal 32 karakter), tetap/permanen.
# Generate dengan: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=65652c6d045185f15ef5486eafc88dcc2752ef22ce3d6adcccf86e54cedb2c76c4fbaf304b4ca3560a857db75563c59a
JWT_EXPIRES_IN=7d

# ===== Webhook Security =====
WEBHOOK_SECRET=ganti_dengan_string_rahasia_acak_untuk_webhook

# ===== CORS =====
# Domain frontend kamu, pisahkan dengan koma jika lebih dari satu.
# Kalau frontend & backend di satu project Vercel yang sama, "*" sudah aman.
FRONTEND_ORIGIN=*
