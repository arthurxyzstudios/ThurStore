# ===== Zakki Gateway =====
ZAKKI_TOKEN=22ab8cb71fe2bb
ZAKKI_API=https://qris.zakki.store

# ===== Auth =====
# Isi dengan string random panjang (minimal 32 karakter). Generate dengan:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=ganti_dengan_string_random_panjang_minimal_32_karakter
JWT_EXPIRES_IN=7d

# ===== Webhook Security =====
WEBHOOK_SECRET=ganti_dengan_string_rahasia_acak_untuk_webhook

# ===== Server =====
PORT=3001
NODE_ENV=production

# ===== CORS =====
FRONTEND_ORIGIN=http://localhost:3000
